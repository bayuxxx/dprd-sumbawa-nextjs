# ==============================================================
# Template .env untuk Production Docker
# Salin file ini ke .env.production dan isi nilainya
# JANGAN commit file .env.production ke Git!
# ==============================================================

# ── Database ─────────────────────────────────────────────────
# Jika MySQL ada di dalam Docker Compose, gunakan nama service sebagai host:
DATABASE_URL="mysql://dprd_user:GANTI_PASSWORD_DB@db:3306/dprd_sumbawa"

# ── MySQL (untuk Docker Compose service 'db') ─────────────────
MYSQL_ROOT_PASSWORD=GANTI_ROOT_PASSWORD
MYSQL_DATABASE=dprd_sumbawa
MYSQL_USER=dprd_user
MYSQL_PASSWORD=GANTI_PASSWORD_DB

# ── App ───────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET=GANTI_DENGAN_STRING_RANDOM_PANJANG_MINIMAL_32_KARAKTER

# ── Next.js ───────────────────────────────────────────────────
NEXT_TELEMETRY_DISABLED=1
