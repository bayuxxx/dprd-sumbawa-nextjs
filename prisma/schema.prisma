// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Banner {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  category  String   @default("Berita Dewan")
  imageUrl  String?  @db.Text
  linkUrl   String?  @db.Text
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("banners")
}

model Berita {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?  @db.Text
  content     String?  @db.LongText
  imageUrl    String?  @db.Text
  category    String   @default("Berita Dewan")
  isPublished Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("beritas")
}

model MasaJabatan {
  id          String     @id @default(cuid())
  periode     String     @unique  // e.g. "2024-2029"
  tahunMulai  Int
  tahunSelesai Int
  isAktif     Boolean    @default(false)
  keterangan  String?    @db.Text
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  pimpinan    Pimpinan[]
  fraksiInfo  FraksiInfo[]

  @@map("masa_jabatan")
}

model Pimpinan {
  id            String       @id @default(cuid())
  name          String
  position      String
  faction       String?
  period        String       @default("2024-2029")
  masaJabatanId String?
  masaJabatan   MasaJabatan? @relation(fields: [masaJabatanId], references: [id], onDelete: SetNull)
  isPast        Boolean      @default(false)
  imageUrl      String?      @db.Text
  bio           String?      @db.Text
  order         Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("pimpinan")
}

model BamusInfo {
  id          String   @id @default(cuid())
  masaJabatan String   @default("2024-2029") // e.g. "2024-2029"
  deskripsi   String?  @db.Text // Paragraph description of Bamus
  isAktif     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  anggota     AnggotaBamus[]

  @@map("bamus_info")
}

model AnggotaBamus {
  id          String     @id @default(cuid())
  name        String
  jabatan     String     // "Ketua" | "Wakil Ketua" | "Anggota" | "Sekretaris"
  faction     String?    // e.g. "Fraksi PKS"
  imageUrl    String?    @db.Text
  order       Int        @default(0)
  bamusInfoId String?
  bamusInfo   BamusInfo? @relation(fields: [bamusInfoId], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("anggota_bamus")
}

model BapemperdaInfo {
  id          String   @id @default(cuid())
  masaJabatan String   @default("2024-2029")
  deskripsi   String?  @db.Text
  isAktif     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  anggota     AnggotaBapemperda[]

  @@map("bapemperda_info")
}

model AnggotaBapemperda {
  id              String          @id @default(cuid())
  name            String
  jabatan         String          // "Ketua" | "Wakil Ketua" | "Anggota" | "Sekretaris"
  faction         String?
  imageUrl        String?         @db.Text
  order           Int             @default(0)
  bapemperdaInfoId String?
  bapemperdaInfo  BapemperdaInfo? @relation(fields: [bapemperdaInfoId], references: [id], onDelete: SetNull)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("anggota_bapemperda")
}

model BanggarInfo {
  id          String   @id @default(cuid())
  masaJabatan String   @default("2024-2029")
  deskripsi   String?  @db.Text
  isAktif     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  anggota     AnggotaBanggar[]

  @@map("banggar_info")
}

model AnggotaBanggar {
  id          String       @id @default(cuid())
  name        String
  jabatan     String       // "Ketua" | "Wakil Ketua" | "Anggota" | "Sekretaris"
  faction     String?
  imageUrl    String?      @db.Text
  order       Int          @default(0)
  banggarInfoId String?
  banggarInfo BanggarInfo? @relation(fields: [banggarInfoId], references: [id], onDelete: SetNull)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("anggota_banggar")
}

model BadanKehormatanInfo {
  id          String   @id @default(cuid())
  masaJabatan String   @default("2024-2029")
  deskripsi   String?  @db.Text
  isAktif     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  anggota     AnggotaBadanKehormatan[]

  @@map("bk_info")
}

model AnggotaBadanKehormatan {
  id          String                  @id @default(cuid())
  name        String
  jabatan     String                  // "Ketua" | "Wakil Ketua" | "Anggota" | "Sekretaris"
  faction     String?
  imageUrl    String?                 @db.Text
  order       Int                     @default(0)
  bkInfoId    String?
  bkInfo      BadanKehormatanInfo?    @relation(fields: [bkInfoId], references: [id], onDelete: SetNull)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@map("anggota_bk")
}


model KomisiInfo {
  id          String   @id @default(cuid())
  namaKomisi  String   // e.g. "Komisi A | Bidang Pemerintahan"
  masaJabatan String   @default("2024-2029")
  deskripsi   String?  @db.Text
  isAktif     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  anggota     AnggotaKomisi[]

  @@map("komisi_info")
}

model AnggotaKomisi {
  id          String       @id @default(cuid())
  name        String
  jabatan     String       // "Ketua" | "Wakil Ketua" | "Sekretaris" | "Anggota"
  faction     String?
  imageUrl    String?      @db.Text
  order       Int          @default(0)
  komisiInfoId String?
  komisiInfo  KomisiInfo?  @relation(fields: [komisiInfoId], references: [id], onDelete: SetNull)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("anggota_komisi")
}

model Sekretariat {
  id        String   @id @default(cuid())
  visi      String?  @db.Text
  misi      String?  @db.Text
  tugas     String?  @db.Text
  fungsi    String?  @db.Text  // JSON array stored as text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sekretariat")
}

model AnggotaSekretariat {
  id           String   @id @default(cuid())
  name         String
  position     String
  unit         String?
  imageUrl     String?  @db.Text
  isSekretaris Boolean  @default(false)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("anggota_sekretariat")
}

model FraksiInfo {
  id          String          @id @default(cuid())
  name        String          // e.g. "Fraksi Partai Gerakan Indonesia Raya"
  shortName   String          // e.g. "Gerindra"
  slug        String          @unique // e.g. "gerindra"
  color         String          @default("#c8102e")
  kursi         Int             @default(0)
  masaJabatanId String?
  masaJabatan   MasaJabatan?    @relation(fields: [masaJabatanId], references: [id], onDelete: SetNull)
  deskripsi     String?         @db.Text
  logoUrl     String?           @db.Text
  isAktif     Boolean         @default(true)
  order       Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  anggota     AnggotaFraksi[]

  @@map("fraksi_info")
}

model AnggotaFraksi {
  id            String       @id @default(cuid())
  name          String
  jabatan       String       // "Ketua Fraksi" | "Wakil Ketua" | "Sekretaris" | "Anggota"
  faction       String?
  imageUrl      String?      @db.Text
  order         Int          @default(0)
  fraksiInfoId  String?
  fraksiInfo    FraksiInfo?  @relation(fields: [fraksiInfoId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("anggota_fraksi")
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

model Propemperda {
  id          String           @id @default(cuid())
  tahun       String           @unique
  keterangan  String?          @db.Text
  isAktif     Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  raperda     RancanganPerda[]

  @@map("propemperda")
}

model RancanganPerda {
  id             String       @id @default(cuid())
  judul          String       @db.Text
  status         String       @default("Belum Pembahasan") // "Selesai Pembahasan" | "Proses Pembahasan" | "Belum Pembahasan"
  keterangan     String?      @db.Text
  order          Int          @default(0)
  propemperdaId  String
  propemperda    Propemperda  @relation(fields: [propemperdaId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("rancangan_perda")
}

model Podcast {
  id           String   @id @default(cuid())
  judul        String
  subjudul     String?
  link         String?  @db.Text
  host         String?
  narasumber   String?
  thumbnailUrl String?  @db.Text
  audioUrl     String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("podcasts")
}
